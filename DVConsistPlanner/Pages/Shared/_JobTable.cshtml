@model List<DVConsistPlanner.Models.Job>

@if (Model != null && Model.Count > 0)
{
    <table border="1">
        <tr style="background-color:beige">
            <th>Job Name</th>
            <th>Departing Station</th>
            <th>Arriving Station</th>
            <th>Mass (t)</th>
            <th>Length (m)</th>
            <th>Payout</th>
            <th>w/Bonus</th>
            <th>Actions</th>
        </tr>
        @foreach (var job in Model)
        {
            <tr>
                <td><a asp-page="/Jobs/EditJob" asp-route-id="@job.ID">@job.JobName</a></td>
                <td>@job.Departing.Name</td>
                <td>@job.Arriving.Name</td>
                <td style="text-align:center;">@String.Format("{0:N2}", job.TrainMass)</td>
                <td style="text-align:center;">@String.Format("{0:N2}", job.TrainLength)</td>
                <td style="text-align:center;">@String.Format("{0:C2}", job.Payout)</td>
                <td style="text-align:center;">@String.Format("{0:C2}", job.BonusPayout)</td>
                <td style="text-align:center;">
                    <a asp-page-handler="DeleteJob" asp-route-id="@job.ID" onclick="return confirm('Are you sure you want to delete this job?')">Delete</a>
                </td>
            </tr>
        }
    </table>
}
else
{
    <p style="text-align:center; color: #666;">No jobs in this consist</p>
}