@model List<DVConsistPlanner.Models.Locomotive>

@if (Model != null && Model.Count > 0)
{
    <table border="1">
        <tr style="background-color:beige">
            <th>Identification</th>
            <th>Classification</th>
            <th>Type</th>
            <th>Mass (t)</th>
            <th>Length (m)</th>
            <th>Load Rating (t)</th>
            <th>Actions</th>
        </tr>
        @foreach (var loco in Model)
        {
            <tr>
                <td><a asp-page="/Locomotives/EditLocomotive" asp-route-id="@loco.ID">@loco.TrainID</a></td>
                <td>@loco.Classification</td>
                <td>@loco.Type</td>
                <td style="text-align:center;">@String.Format("{0:N2}", loco.Mass)</td>
                <td style="text-align:center;">@String.Format("{0:N2}", loco.Length)</td>
                <td style="text-align:center;">@String.Format("{0:N2}", loco.LoadRating)</td>
                <td style="text-align:center;">
                    <a asp-page-handler="DeleteLocomotive" asp-route-id="@loco.ID" onclick="return confirm('Are you sure you want to delete this locomotive?')">Delete</a>
                </td>
            </tr>
        }
    </table>
}
else
{
    <p style="text-align:center; color: #666;">No locomotives in this consist</p>
}